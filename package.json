  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:master": "npx prisma migrate dev --schema=prisma/master.prisma",
    "db:generate": "npx prisma generate && npx prisma generate --schema=prisma/master.prisma",
    "db:push": "npx prisma db push",
    "db:push:master": "npx prisma db push --schema=prisma/master.prisma"
  },
